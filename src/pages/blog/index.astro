---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="Blog | BlogDeco" description="Read interior decoration ideas by room and style.">
  <h1 class="mb-8 text-3xl font-bold">Blog</h1>
  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => <PostCard href={`/blog/${post.slug}`} title={post.data.title} image={post.data.featuredImage} description={post.data.description} author={post.data.author} date={post.data.date} />)}
  </div>
</BaseLayout>
