---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | BlogDeco" description="Send a message to BlogDeco.">
  <section class="mx-auto max-w-2xl">
    <h1 class="mb-6 text-3xl font-bold">Contact</h1>
    <form class="space-y-4" method="POST" action="/api/contact">
      <input class="w-full rounded-xl border border-slate-300 px-4 py-3" type="text" name="name" placeholder="Name" required />
      <input class="w-full rounded-xl border border-slate-300 px-4 py-3" type="email" name="email" placeholder="Email" required />
      <textarea class="h-40 w-full rounded-xl border border-slate-300 px-4 py-3" name="message" placeholder="Message" required></textarea>
      <button class="rounded-full bg-sky px-6 py-3 font-semibold text-white" type="submit">Send message</button>
    </form>
  </section>
</BaseLayout>
