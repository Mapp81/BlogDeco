---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About Me | BlogDeco" description="Meet the editor behind BlogDeco.">
  <section class="mx-auto max-w-3xl space-y-4">
    <h1 class="text-3xl font-bold">About Me</h1>
    <p>Hi! I'm the creator of BlogDeco, where I share practical decoration ideas to make every room look better and work better.</p>
    <p>My goal is to help you create spaces that feel calm, organized, and beautiful with realistic budgets.</p>
  </section>
</BaseLayout>
