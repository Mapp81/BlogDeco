---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="FAQs | BlogDeco" description="Frequently asked questions.">
  <h1 class="mb-6 text-3xl font-bold">FAQs</h1>
  <div class="space-y-4">
    <div class="card"><h2 class="font-semibold">How often do you post?</h2><p class="text-sm text-steel">New posts are added weekly.</p></div>
    <div class="card"><h2 class="font-semibold">Do you share product recommendations?</h2><p class="text-sm text-steel">Yes, we include selected tools and decor with affiliate links.</p></div>
  </div>
</BaseLayout>
