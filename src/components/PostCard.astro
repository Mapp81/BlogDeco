---
interface Props {
  href: string;
  title: string;
  image: string;
  description: string;
  author?: string;
  date?: string;
}

const { href, title, image, description } = Astro.props;
---

<article class="card flex h-full flex-col">
  <img class="mb-4 h-48 w-full rounded-xl object-cover" src={image} alt={title} loading="lazy" />
  <h3 class="mb-2 text-lg font-semibold">{title}</h3>
  <div class="mb-3 text-sm text-steel flex items-baseline gap-1">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" class="opacity-60 "><path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <span class="text-xs opacity-60">{Astro.props.author ?? '—'}</span>
    <span class="text-xs opacity-60">-</span>
    <span class="text-xs opacity-60">{Astro.props.date ? new Date(Astro.props.date).toLocaleDateString('es-ES') : ''}</span>
  </div>
  <p class="mb-4 text-sm text-steel" style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;">{description}</p>
  <a href={href} class="mt-auto text-sm font-semibold text-sky">Learn more</a>
</article>
